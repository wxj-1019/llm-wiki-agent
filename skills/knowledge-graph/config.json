{
  "name": "knowledge-graph",
  "version": "1.0.0",
  "type": "action",
  "triggers": ["build graph", "构建图谱"],
  "priority": 15,
  "model": "default",
  "max_tokens": 1024,
  "auto_save": false,
  "timeout_sec": 600,
  "parameters": {
    "temperature": 0.1
  },
  "permissions": {
    "read_wiki": true,
    "write_wiki": true,
    "read_raw": false,
    "execute_commands": true,
    "network_access": false
  }
}
