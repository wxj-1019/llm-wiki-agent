# LLM Provider Configuration
# Format for litellm: provider/model-name
# Examples:
#   anthropic/claude-3-5-sonnet-latest
#   openai/gpt-4
#   deepseek/deepseek-chat
#   deepseek/deepseek-coder
LLM_MODEL=deepseek/deepseek-chat
LLM_MODEL_FAST=deepseek/deepseek-chat

# API Keys - uncomment and set the one matching your provider
# Do NOT commit this file with real keys. Copy to .env and keep it private.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
