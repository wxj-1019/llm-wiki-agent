{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LLM Wiki Agent",
  "version": "0.1.0",
  "identifier": "com.llmwikiagent.app",
  "build": {
    "beforeBuildCommand": "cd ../wiki-viewer && npm run build",
    "beforeDevCommand": "cd ../wiki-viewer && npm run dev",
    "frontendDist": "../wiki-viewer/dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "LLM Wiki Agent",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool"
  }
}
